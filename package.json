{
  "name": "summative-lab-spa-portfolio-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "json-server --watch db.json --port 3001",
    "dev-full": "concurrently \"npm run server\" \"npm run dev\"",
