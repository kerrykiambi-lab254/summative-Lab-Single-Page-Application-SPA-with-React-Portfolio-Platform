    "test:ui": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.18.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@vitejs/plugin-react": "^5.3.0",
    "concurrently": "^8.2.0",
    "json-server": "^0.17.3",
    "jsdom": "^23.0.0",
    "vite": "^5.4.0",
    "vitest": "^1.9.0"
  }
}
